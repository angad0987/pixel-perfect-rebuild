    margin-top: 0px;
    font-size: .95rem;
    line-height: 1.3;
    word-break: break-word;
    display: flex;
    flex-direction: row;
    align-items: center;
    font-size: 18px;
    font-weight: 400;
    border-top: 1px solid #eee;
    color: #5b5b5b;
    padding: 5px 10px 5px 10px;
    white-space: nowrap;
    overflow: hidden;
