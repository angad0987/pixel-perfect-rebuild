function generateCaptcha() {
    let num1, num2, operator, question, answer;
    const operators = ['+', '-'];
    operator = operators[Math.floor(Math.random() * operators.length)];
    num1 = Math.floor(Math.random() * 10) + 1;
    num2 = Math.floor(Math.random() * 10) + 1;

    if (operator === '-') {
        // Ensure positive answer for subtraction
        if (num1 < num2) [num1, num2] = [num2, num1];
    }

    question = `${num1} ${operator} ${num2}`;
    answer = operator === '+' ? num1 + num2 : num1 - num2;
    return { question, answer };
}

  let captcha = generateCaptcha();

  function setCaptcha() {
    document.getElementById('captcha-label').textContent = ` ${captcha.question}?`;
    document.getElementById('captcha-answer').value = '';
  }

  document.addEventListener('DOMContentLoaded', function() {
    setCaptcha();

    // Reset button functionality
    document.getElementById('captcha-reset').addEventListener('click', function() {
      captcha = generateCaptcha();
      setCaptcha();
    });

    // Validate captcha on form submit
    document.getElementById('contact-form').addEventListener('submit', function(e) {
      const userAnswer = document.getElementById('captcha-answer').value;
      if (parseInt(userAnswer, 10) !== captcha.answer) {
		    showToast("Incorrect CAPTCHA answer. Please try again.'", "error");
        e.preventDefault();
        captcha = generateCaptcha();
        setCaptcha();
      }
    });
  });



	//nice-select
	$(document).ready(function () {
		$('select').niceSelect();
	});



document.addEventListener("DOMContentLoaded", function () {
    const testimonials = document.querySelectorAll(".testimonial-wrapper");

    testimonials.forEach(wrapper => {
        const textEl = wrapper.querySelector(".testimonial-text");
        const btn = wrapper.querySelector(".read-more-btn");

        // Calculate 3-line height based on line-height
        const lineHeight = parseFloat(getComputedStyle(textEl).lineHeight);
        const maxLines = 2;
        const maxHeight = lineHeight * maxLines;

        if (textEl.scrollHeight > maxHeight) {
            wrapper.classList.add("show-read-more");

            btn.addEventListener("click", () => {
                textEl.classList.toggle("expanded");
                btn.textContent = textEl.classList.contains("expanded") ? "See less" : "See more";
            });
        }
    });
});


  window.addEventListener('DOMContentLoaded', function() {
    var dialog = document.getElementById('dialog');
    if (dialog) dialog.showModal();
  });



})(jQuery);
