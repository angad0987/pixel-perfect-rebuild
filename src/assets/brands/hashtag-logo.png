}

.wp-block-latest-posts.is-grid li {
    margin: 0 1.25em 1.25em 0;
    font-size: .95rem;
    line-height: 1.3;
    text-align: center;
}

.ast-separate-container .ast-article-post{

    margin: 10px;
    background: #fff;
    border-radius: 10px;
    position: relative;
    box-shadow: 0 2px 6px rgb(0 16 61 / 4%);
    transition-duration: .4s;
    transition-property: box-shadow;
    transition-timing-function: cubic-bezier(.3,.3,.5,1);
}
.ast-separate-container .ast-article-post {
    border-bottom: 1px solid var(--ast-border-color);
}

.ast-separate-container .post-navigation {
    display: none;
    border-top: 0;
    padding-left: 3.33333em;
    padding-right: 3.33333em;
}
.ast-related-posts-wrapper .ast-related-post, .ast-related-post-featured-section {
    padding: 0;
    margin: 0;
    width: 100%;
    position: relative;
    background: #fff;
}
.ast-separate-container .ast-single-related-posts-container {
    padding: 0em;
}
.wp-block-latest-posts__featured-image a {
    display: flex;
    justify-content: center;
    align-items: center;
}
.entry-content ul, .entry-content ol {
    margin: 0;
    padding: 0;
}
.ast-single-related-posts-container {
    background-color: #efefef;
    background-image: none;
}
.ast-related-post-featured-section {
    display: flex;
    height: 215px;
    width: 100%;
    justify-content: center;
    align-items: center;
	border-radius: 10px;
}
.ast-related-posts-wrapper .ast-related-post {
    padding: 0;
    margin: 0;
    width: 100%;
    position: relative;
    background: #fff;
    display: flex;
    width: 100%;
    justify-content: center;
    align-items: center;
    border-radius: 10px;
}
.ast-related-post-title {
    word-break: break-word;
    display: flex;
    flex-direction: row;
    align-items: center;
    padding-top: 8px;
    font-size: 13px;
    border-top: 1px solid #eee;
    margin-top: 8px;
    color: #5b5b5b;
	  padding-left:20px;
	text-align:left;
}
.wp-elements-bffd531e1eeb3205e56b2a37ff365617 a {
    display: block;
    margin-top: 24px;
    color: var(--wp--preset--color--ast-global-color-0);
}

p {
    margin-bottom: 0.5em;
}
.widget {
    margin-bottom: 0.5em;
}
.ast-separate-container #primary{
  margin: 0;
  padding: 0;
}
.ast-separate-container .ast-article-single {
    padding: 0em;
}
.wp-block-uagb-container.uagb-block-b5aa58be{
justify-content: start;
}
.wp-block-latest-posts__post-title {
    word-break: break-word;
    display: flex;
    flex-direction: row;
    align-items: center;
    font-size: 16px;
    font-weight: 400;
    padding: 5px 10px 5px 10px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
	margin-bottom: 0.5em;
  border-top: 1px solid #eee;
  padding-top: 0.5em;
}
.ast-related-posts-inner-section {
    height: auto;
}
.wp-block-uagb-container.uagb-block-b5aa58be {
    box-shadow: 0px 0px #00000070;
    padding-top: 10px;
    padding-bottom: 10px;
    padding-left: 10px;
    padding-right: 10px;
    row-gap: 20px;
    column-gap: 20px;
    overflow: visible;
    border-color: inherit;
    align-items: center;
    justify-content: center;
    flex-wrap: nowrap;
}
.editor-styles-wrapper {
    counter-reset: footnotes;
    display: none;
}
@media (min-width: 640px)
	{.ast-separate-container .ast-article-post {
    padding: 1em 1em;
		width:18%;
    float: left;
    white-space: normal;
    overflow: hidden;
