}
._list-body ul li {
    width: 25%;
    margin: 12px 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.6;
}
a {
    color: #333;
    text-decoration: none !important;
}

.logos-list {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
}
.portfolioFilter {
    margin-bottom: 30px;
}
.portfolioFilter a {
    display: inline-block;
    margin: 3px 2px;
    font-size: 12px;
    text-transform: uppercase;
    padding: 7px 12px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.4s ease-in-out;
    color: #333;
    border: 1px solid #ff5858;
    border-radius: 3px;
}
