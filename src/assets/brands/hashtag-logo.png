.bmc-btn {
    min-width: 210px;
    color: #ffffff;
    background-color: #1173ee !important;
    height: 60px;
    border-radius: 10px;
    font-size: 24px;
    font-weight: Bold;
    border: none;
    padding: 0px 24px;
    line-height: 27px;
    text-decoration: none !important;
    display: inline-flex !important;
    align-items: center;
    font-family: 'Arial', cursive !important;
    -webkit-box-sizing: border-box !important;
    box-sizing: border-box !important;
}
.bmc-btn svg {
    height: 32px !important;
    margin-bottom: 0px !important;
    box-shadow: none !important;
    border: none !important;
    vertical-align: middle !important;
    transform: scale(0.9);
    flex-shrink: 0;
}
.bmc-btn-text {
    margin-left: 8px;
    display: inline-block;
    line-height: 0;
    width: 100%;
    flex-shrink: 0;
    font-family: [FONT] !important;
}
.uagb-post__inner-wrap {
    margin: 0 1.25em 1.25em 0;
    font-size: .95rem;
    line-height: 1.3;
    text-align: center;
}
.uagb-post__inner-wrap {
    background: #fff;
    border-radius: 10px;
    position: relative;
    box-shadow: 0 2px 6px rgb(0 16 61 / 4%);
    transition-duration: .4s;
    transition-property: box-shadow;
    transition-timing-function: cubic-bezier(.3,.3,.5,1);
}
.wp-block-uagb-post-grid {
    display: flex;
    height: 215px;
    width: 100%;
    justify-content: center;
    align-items: center;
}

.uagb-post__inner-wrap {
    height: 100%;
    display: flex;
    align-items: center;
    flex-direction: column;
    justify-content: center;
}
.wp-block-search.aligncenter .wp-block-search__inside-wrapper {
    margin: auto;
    flex-grow: 1;
    align-self: stretch;
    border: 0;
    background: #fff;
    font-size: 1.03rem;
}
.wp-block-search__inside-wrapper .wp-block-search__input {
    flex-grow: 1;
    align-self: stretch;
    border: 0;
    background: #fff;
    margin-left: 18px;
    font-size: 1.03rem;
}
@media(max-width:767px) {
._list-body ul li {
width:50%;
}
}
.entry-title {
    margin-bottom: 0.2em;
    border-top: 1px solid #eee;
    padding-top: 0.2em;
}
.entry-header {
    margin-bottom: 0.2em;
    word-wrap: break-word;
}
._list-body ul {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    text-align: left;
}

._list-body ul li {
    margin: 0;
    padding: 10px 10px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.6;
    border: 1px solid rgb(209, 215, 217)
}
.divide-gray-150>:not([hidden])~:not([hidden]) {
    --tw-divide-opacity: 1;
    border-color: rgb(227 227 227 / var(--tw-divide-opacity));
}
.divide-y>:not([hidden])~:not([hidden]) {
    --tw-divide-y-reverse: 0;
    border-top-width: calc(1px* calc(1 - var(--tw-divide-y-reverse)));
    border-bottom-width: calc(1px* var(--tw-divide-y-reverse));
}
@media (min-width: 768px) {
    .md\:p-12 {
        padding: 3rem;
    }
}
@media (min-width: 640px) {
    .sm\:gap-16 {
        gap: 4rem;
    }
}
@media (min-width: 640px) {
    .sm\:grid-cols-2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}
@media all {
  #page .site-content {
    flex-grow: 1;
    background: #efefef;
  }
}
header.entry-header:not(.related-entry-header) .entry-title {
    font-weight: 600;
    font-size: 32px;
    font-size: 2rem;
    display: none;
}
@media all {
  .page .entry-header {
    margin-bottom: 10px;
    margin-top: 70px;
  }
}
@media (min-width: 922px) {
    .ast-no-sidebar .site-content .ast-article-image-container--wide {
        margin-left: -120px;
        margin-right: -120px;
        max-width: unset;
        width: unset;
        display: none;
    }
}
@media (min-width: 1200px) {
