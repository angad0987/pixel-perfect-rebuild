data-ast-blocks-layout="true" itemprop="text"><div class="wp-block-cover alignfull" style="min-height:300px;aspect-ratio:unset;"><span aria-hidden="true" class="wp-block-cover__background has-background-dim-100 has-background-dim" style="background-color:#1847b9"></span><div class="wp-block-cover__inner-container is-layout-flow wp-block-cover-is-layout-flow"><h2 class="wp-block-heading has-text-align-center has-ast-global-color-5-color has-text-color has-link-color wp-elements-d8c97b0f5a6af8a13280e761180ddabf" style="font-size:24px">Brand logos free to download</h2><p class="has-text-align-center wp-block-paragraph"><mark style="background-color:rgba(0, 0, 0, 0)" class="has-inline-color has-ast-global-color-5-color">Find your logos in the Logoshape collection of high-quality vector logos. Brand logos free to download to suit your needs.</mark></p><div class="inherit-container-width wp-block-group alignwide is-layout-constrained wp-block-group-is-layout-constrained" style="border-style:none;border-width:0px;border-radius:0px"><form role="search" method="get" action="https://www.logoshape.com/" class="wp-block-search__button-inside wp-block-search__icon-button aligncenter wp-block-search"    ><label class="wp-block-search__label screen-reader-text" for="wp-block-search__input-1"  style="font-size: 20px">Search</label><div class="wp-block-search__inside-wrapper has-border-color"  style="width: 850px;border-color: var(--ast-global-color-5);border-radius: calc(5px + 4px)"><input class="wp-block-search__input" id="wp-block-search__input-1" placeholder="Search for brands, companies..." value="" type="search" name="s" required  style="border-radius: 5px;font-size: 20px"/><button aria-label="" class="wp-block-search__button has-background has-luminous-vivid-amber-background-color has-icon wp-element-button" type="submit"  style="border-radius: 5px;font-size: 20px"><svg class="search-icon" viewBox="0 0 24 24" width="24" height="24"> <path d="M13 5c-3.3 0-6 2.7-6 6 0 1.4.5 2.7